{
  "name": "gmsim",
  "version": "0.48.0",
  "private": true,
  "description": "Authentic NFL GM simulator — single-player, 32-team Living League",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
