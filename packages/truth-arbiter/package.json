{
  "name": "@gmsim/truth-arbiter",
  "version": "0.116.0",
  "private": true,
  "type": "module",
  "description": "Ground-truth corpus of real NFL draft history (2014-2026) used to verify GMSim's generated rosters and draft classes.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "scrape": "tsc -p tsconfig.json && node dist/scrape.js",
    "embed": "tsc -p tsconfig.json && node dist/embed.js",
    "search": "tsc -p tsconfig.json && node dist/search.js",
    "arbiter": "tsc -p tsconfig.json && node dist/arbiter.js",
    "class": "tsc -p tsconfig.json && node dist/arbiter-class.js",
    "outcomes": "tsc -p tsconfig.json && node dist/arbiter-outcomes.js",
    "adjudicate": "tsc -p tsconfig.json && node dist/skill-adjudicator.js",
    "magistrate": "tsc -p tsconfig.json && node dist/magistrate.js",
    "liquidator": "tsc -p tsconfig.json && node dist/liquidator.js",
    "star": "tsc -p tsconfig.json && node dist/star-separation.js",
    "conversion": "tsc -p tsconfig.json && node dist/conversion.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf .turbo dist",
    "ras": "tsc -p tsconfig.json && node dist/ras.js",
    "nmdd": "tsc -p tsconfig.json && node dist/nmdd.js",
    "class-talent": "tsc -p tsconfig.json && node dist/class-talent.js",
    "ndb": "tsc -p tsconfig.json && node dist/ndb.js",
    "ombudsman": "tsc -p tsconfig.json && node dist/ombudsman.js"
  },
  "dependencies": {
    "node-html-parser": "^6.1.13"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  }
}
