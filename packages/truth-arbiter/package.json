{
  "name": "@gmsim/truth-arbiter",
  "version": "0.159.0",
  "private": true,
  "type": "module",
  "description": "Ground-truth corpus of real NFL draft history (2014-2026) used to verify GMSim's generated rosters and draft classes.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "gates": "tsc -p tsconfig.json && node dist/gates.js",
    "scrape": "tsc -p tsconfig.json && node dist/corpus/scrape.js",
    "embed": "tsc -p tsconfig.json && node dist/corpus/embed.js",
    "search": "tsc -p tsconfig.json && node dist/corpus/search.js",
    "arbiter": "tsc -p tsconfig.json && node dist/draft-model/arbiter.js",
    "class": "tsc -p tsconfig.json && node dist/draft-model/arbiter-class.js",
    "outcomes": "tsc -p tsconfig.json && node dist/draft-model/arbiter-outcomes.js",
    "adjudicate": "tsc -p tsconfig.json && node dist/sim/skill-adjudicator.js",
    "magistrate": "tsc -p tsconfig.json && node dist/sim/magistrate.js",
    "barterer": "tsc -p tsconfig.json && node dist/sim/barterer.js",
    "goatinator": "tsc -p tsconfig.json && node dist/sim/goatinator.js",
    "scorekeeper": "tsc -p tsconfig.json && node dist/sim/scorekeeper.js",
    "actuary": "tsc -p tsconfig.json && node dist/sim/actuary.js",
    "headhunter": "tsc -p tsconfig.json && node dist/sim/headhunter.js",
    "liquidator": "tsc -p tsconfig.json && node dist/cap/liquidator.js",
    "star": "tsc -p tsconfig.json && node dist/sim/star-separation.js",
    "conversion": "tsc -p tsconfig.json && node dist/sim/conversion.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf .turbo dist",
    "ras": "tsc -p tsconfig.json && node dist/draft-model/ras.js",
    "nmdd": "tsc -p tsconfig.json && node dist/media/nmdd.js",
    "class-talent": "tsc -p tsconfig.json && node dist/draft-model/class-talent.js",
    "ndb": "tsc -p tsconfig.json && node dist/media/ndb.js",
    "ombudsman": "tsc -p tsconfig.json && node dist/media/ombudsman.js",
    "beast": "tsc -p tsconfig.json && node dist/corpus/beast.js",
    "pff": "tsc -p tsconfig.json && node dist/corpus/pff.js",
    "scribe": "tsc -p tsconfig.json && node dist/voice/scribe.js",
    "narrator": "tsc -p tsconfig.json && node dist/voice/narrator.js"
  },
  "dependencies": {
    "hyparquet": "^1.26.0",
    "hyparquet-compressors": "^1.1.1",
    "node-html-parser": "^6.1.13"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "pdfjs-dist": "^6.0.227",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  }
}
